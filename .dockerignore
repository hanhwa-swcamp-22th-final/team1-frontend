# 의존성 설치 결과물 (이미지 안에서 npm ci로 재설치)
node_modules/

# Vite 빌드 결과물은 CI에서 미리 생성한 뒤 이미지에 포함
!dist/
!dist/**

# 소스맵 파일 (배포 이미지에 불필요)
*.map

# 환경 변수 파일 (민감 정보 포함 가능, 런타임에서 주입)
.env
.env.*
!.env.example

# Git 파일
.git/
.gitignore
.gitattributes
.github/

# IDE 설정 파일
.idea/
.vscode/
*.iml

# OS 메타데이터
.DS_Store
Thumbs.db

# 테스트 파일
**/*.test.*
**/*.spec.*

# 목 서버 (개발용, 프로덕션 불필요)
mock-server/

# Dockerfile 자체
Dockerfile
.dockerignore

# 로그 파일
*.log
logs/

# 문서
docs/
README.md
